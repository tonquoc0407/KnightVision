# KnightVision local environment overrides.
# Copy this file to .env if you want to centralize optional settings.

# DuckDB warehouse used by dbt and the dashboard.
KNIGHTVISION_DUCKDB_PATH=warehouse/knightvision.duckdb

# dbt thread count. Lower to 1 if your local DuckDB/dbt runtime is unstable.
KNIGHTVISION_DBT_THREADS=4

# Optional Stockfish binary for blunder analytics.
# Example: /usr/bin/stockfish
STOCKFISH_PATH=

# Optional Telegram notification settings for Airflow.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional Airflow container user mapping for local Docker runs.
# Rootless Podman may need AIRFLOW_UID=0 so containers can write to the
# bind-mounted project data directory during local smoke tests.
AIRFLOW_UID=50000
